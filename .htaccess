# 1. Zorg ervoor dat bestanden zoals fonts en svg correct geladen worden
AddType font/woff2 .woff2
AddType font/woff .woff
AddType font/ttf .ttf
AddType image/svg+xml .svg
AddType image/webp .webp
AddType application/javascript .js
AddType text/css .css

# 2. Gzip compressie voor een snellere website
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 3. Cross-Origin support voor fonts
<IfModule mod_headers.c>
  <FilesMatch "\.(ttf|otf|eot|woff|woff2|svg)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# 4. Cache-Control headers voor statische bestanden
<IfModule mod_headers.c>
  # Fonts en afbeeldingen: 1 jaar
  <FilesMatch "\.(woff|woff2|webp|jpg|jpeg|png|svg|ico)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
  # CSS en JS: 1 week (kunnen vaker wijzigen)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=604800, public"
  </FilesMatch>
</IfModule>

# 4. Redirects voor HTTPS en non-WWW
RewriteEngine On

# Forceer HTTPS (veiligheid)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Forceer naar boterzout.nl (verwijder www)
RewriteCond %{HTTP_HOST} ^www\.boterzout\.nl [NC]
RewriteRule ^(.*)$ https://boterzout.nl/$1 [L,R=301]